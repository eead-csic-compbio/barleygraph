# Example config for build_PHG_database.sh
# Required values
DATABASE_NAME=Pan20
REFERENCE_FASTA=/path/to/MorexV3.fa
REFERENCE_GFF=/path/to/MorexV3.gff
REFERENCE_NAME=MorexV3

# Provide one or more assembly sources as local paths or URLs.
# Each genome entry is written on its own line so the count is obvious.
ASSEMBLYS=/path/to/Akashinriki.fa
ASSEMBLYS=/path/to/Barke.fa
ASSEMBLYS=https://example.org/Chiba.fa

# Optional overrides
THREADS=32
CONDA_ENV=phgv2-conda
GMAP_BUILD_CMD=/usr/local/bin/gmap_build
